{
  "name": "LLM from Scratch",
  "dockerComposeFile": "../docker-compose.yml",
  "service": "llm-lab",
  "workspaceFolder": "/app",
  
  // 1. 打通网络：让容器认得宿主机的 7897 端口
  "runArgs": [
    "--add-host=host.docker.internal:host-gateway"
  ],

  // 2. 强行镇压 VS Code 的错误环境变量，绑定到正确的网关
  "containerEnv": {
    "HTTP_PROXY": "http://host.docker.internal:7897",
    "HTTPS_PROXY": "http://host.docker.internal:7897",
    "http_proxy": "http://host.docker.internal:7897",
    "https_proxy": "http://host.docker.internal:7897",
    "NO_PROXY": "localhost,127.0.0.1"
  },

  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-python.debugpy",
        "ms-python.vscode-pylance",
        "github.copilot",
        "github.copilot-chat"
      ],
      "settings": {
        "python.defaultInterpreterPath": "/usr/local/bin/python",
        "python.linting.enabled": true,
        "python.linting.pylintEnabled": true,
        "http.proxy": "http://host.docker.internal:7897",
        "http.proxySupport": "override",
        "http.proxyStrictSSL": false
      }
    }
  },

 // 1. 【新增】：让容器自动创建一个名叫 vscode 的“普通账号”，并赋予它免密码的 sudo 权限
  "features": {
    "ghcr.io/devcontainers/features/common-utils:2": {
      "username": "ayton",
      "upgradePackages": false
    }
  },

  // 2. 【修改】：因为你现在是普通用户了，所以前面的 apt-get 必须加上 sudo
  "postCreateCommand": "sudo apt-get update && sudo apt-get install -y libx11-dev libxkbfile-dev libsecret-1-dev",

  // 3. 【最核心的修复】：剥夺 root 身份，以普通用户登录，Claude 就不会报错了！
  "remoteUser": "ayton"
}